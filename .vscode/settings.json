{
  "eslint.validate": ["javascript", "vue"],
  "eslint.useFlatConfig": false,
  "eslint.lintTask.enable": true,
  "eslint.run": "onType",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.workingDirectories": ["."],
  "eslint.options": {
    "extensions": [".js", ".vue"]
  }
}
